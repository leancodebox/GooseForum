{
  "exclude_dirs": [
    ".git",
    "node_modules",
    "dist",
    "tmp",
    "storage",
    "app/models/deprecatedmodels",
    "app/service/datamigration"
  ],
  "scan": {
    "extensions": [
      ".go",
      ".ts",
      ".vue",
      ".md",
      ".gohtml",
      ".css",
      ".json"
    ],
    "keywords": [
      "article",
      "articles",
      "reply",
      "replies"
    ]
  },
  "rules": [
    {
      "name": "site-topic-i18n-calls",
      "description": "Rename site-facing topic detail i18n calls from article.* to topic.* in current Vue files.",
      "paths": [
        "resource/src/site/pages/TopicPage.vue",
        "resource/src/site/components/PostComposer.vue",
        "resource/src/site/components/PostPositionRail.vue"
      ],
      "replacements": [
        {
          "type": "literal",
          "from": "article.",
          "to": "topic."
        }
      ]
    },
    {
      "name": "site-topic-i18n-namespace",
      "description": "Rename only the top-level locale namespace key from article to topic for the topic detail block.",
      "paths": [
        "resource/src/locales/zh.ts",
        "resource/src/locales/en.ts",
        "resource/src/locales/ja.ts",
        "resource/src/locales/it.ts"
      ],
      "replacements": [
        {
          "type": "regex",
          "pattern": "(?m)^ {2}article:\\s*\\{",
          "to": "  topic: {"
        }
      ]
    },
    {
      "name": "docs-topic-wording",
      "description": "Fix the two known frontend/docs wording leftovers after topic/post migration.",
      "paths": [
        "docs/frontend/ui-spec.md",
        "docs/frontend/site-design-system-plan.zh.md"
      ],
      "replacements": [
        {
          "type": "literal",
          "from": "topic list to article detail",
          "to": "topic list to topic detail"
        },
        {
          "type": "literal",
          "from": "article/comment prose",
          "to": "topic/post prose"
        }
      ]
    }
  ]
}
