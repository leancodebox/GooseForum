<!DOCTYPE html>
<html lang="zh-CN" data-theme="{{.Theme}}">
<head>
    {{template "common-head.gohtml" .}}
    <!-- V2 Styles & Scripts -->
    {{ViteEntry `src/gf-main.ts`}}
    <style>
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased selection:bg-blue-100 selection:text-blue-900">
    <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8" x-data="loginHandler()" x-cloak>
        <!-- Card -->
        <div class="max-w-4xl w-full bg-white rounded-2xl shadow-[0_2px_15px_-3px_rgba(0,0,0,0.07),0_10px_20px_-2px_rgba(0,0,0,0.04)] border border-gray-100 overflow-hidden flex flex-col md:flex-row">
            
            <!-- Left Side: Forms -->
            <div class="w-full md:w-1/2 p-6 md:p-10 flex flex-col justify-center">
                <!-- Logo/Header -->
                <div class="mb-6">
                    <h2 class="text-3xl font-bold text-gray-900" x-text="getHeaderTitle()"></h2>
                    <p class="mt-1 text-sm text-gray-600" x-show="activeTab === 'login'">{{call .T "welcome_back"}}</p>
                    <p class="mt-1 text-sm text-gray-600" x-show="activeTab === 'register'">{{call .T "create_account"}}</p>
                    <p class="mt-1 text-sm text-gray-600" x-show="activeTab === 'forgot'">{{call .T "reset_password"}}</p>
                </div>

                <!-- Tabs -->
                <div class="flex p-1 space-x-1 bg-gray-50 rounded-xl mb-5" x-show="activeTab !== 'forgot'">
                    <button class="w-full py-1.5 text-sm font-medium leading-5 rounded-lg focus:outline-none transition-all duration-200"
                        :class="activeTab === 'login' ? 'bg-white text-blue-600 shadow-sm ring-1 ring-black/5' : 'text-gray-500 hover:text-gray-700'"
                        @click="switchTab('login')">
                        {{call .T "login_btn"}}
                    </button>
                    <button class="w-full py-1.5 text-sm font-medium leading-5 rounded-lg focus:outline-none transition-all duration-200"
                        :class="activeTab === 'register' ? 'bg-white text-blue-600 shadow-sm ring-1 ring-black/5' : 'text-gray-500 hover:text-gray-700'"
                        @click="switchTab('register')">
                        {{call .T "register_btn"}}
                    </button>
                </div>

            <!-- Login Form -->
            <form x-show="activeTab === 'login'" @submit.prevent="handleLogin" class="space-y-4" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
                <div class="space-y-3 rounded-md">
                    <div>
                        <label for="login-username" class="sr-only">{{call .T "username_label"}}</label>
                        <input id="login-username" x-model="loginForm.username" type="text" required class="appearance-none rounded-xl relative block w-full px-4 py-2.5 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="{{call .T "username_placeholder"}}" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.login.username }">
                        <p class="mt-1 text-xs text-red-500" x-show="errors.login.username" x-text="errors.login.username"></p>
                    </div>
                    <div>
                        <label for="login-password" class="sr-only">{{call .T "password_placeholder"}}</label>
                        <input id="login-password" x-model="loginForm.password" type="password" required class="appearance-none rounded-xl relative block w-full px-4 py-2.5 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="{{call .T "password_placeholder"}}" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.login.password }">
                        <p class="mt-1 text-xs text-red-500" x-show="errors.login.password" x-text="errors.login.password"></p>
                    </div>
                    <div>
                        <div class="flex gap-3">
                            <div class="flex-1">
                                <label for="login-captcha" class="sr-only">{{call .T "captcha_placeholder"}}</label>
                                <input id="login-captcha" x-model="loginForm.captcha" type="text" required class="appearance-none rounded-xl relative block w-full px-4 py-2.5 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="{{call .T "captcha_placeholder"}}" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.login.captcha }">
                            </div>
                            <div class="relative w-32 h-[42px] flex-shrink-0 cursor-pointer rounded-xl border border-gray-200 overflow-hidden bg-gray-50 hover:opacity-80 transition-opacity" @click="refreshCaptcha" title="{{call .T "click_to_refresh"}}">
                                <div x-show="captchaLoading || !captchaImg" class="absolute inset-0 flex items-center justify-center animate-pulse">
                                    <svg class="h-5 w-5 text-gray-400 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                </div>
                                <img x-show="!captchaLoading && captchaImg" :src="captchaImg" alt="{{call .T "captcha_placeholder"}}" class="w-full h-full object-cover" />
                            </div>
                        </div>
                        <p class="mt-1 text-xs text-red-500" x-show="errors.login.captcha" x-text="errors.login.captcha"></p>
                    </div>
                </div>

                <div class="flex items-center justify-between mt-2">
                    <div class="text-sm">
                        <a href="#" @click.prevent="switchTab('forgot')" class="font-medium text-blue-600 hover:text-blue-500 transition-colors">
                            {{call .T "forgot_password"}}
                        </a>
                    </div>
                </div>
                
                <div class="rounded-md bg-red-50 p-4" x-show="errors.login.general">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-red-800" x-text="errors.login.general"></h3>
                        </div>
                    </div>
                </div>

                <div>
                    <button type="submit" :disabled="loading.login" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-70 disabled:cursor-not-allowed transition-all shadow-lg shadow-blue-200 hover:shadow-blue-300">
                        <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                            <svg x-show="!loading.login" class="h-5 w-5 text-blue-500 group-hover:text-blue-400 transition-colors" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                            </svg>
                            <svg x-show="loading.login" class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                        </span>
                        <span x-text="loading.login ? '{{call .T "logging_in"}}' : '{{call .T "login_btn"}}'"></span>
                    </button>
                </div>
            </form>

            <!-- Register Form -->
            <form x-show="activeTab === 'register'" @submit.prevent="handleRegister" class="space-y-4" style="display: none;" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
                <div class="space-y-3 rounded-md">
                    <div>
                        <label for="reg-username" class="sr-only">用户名</label>
                        <input id="reg-username" x-model="registerForm.username" type="text" required class="appearance-none rounded-xl relative block w-full px-4 py-2.5 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="用户名" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.register.username }">
                        <p class="mt-1 text-xs text-red-500" x-show="errors.register.username" x-text="errors.register.username"></p>
                    </div>
                    <div>
                        <label for="reg-email" class="sr-only">邮箱</label>
                        <input id="reg-email" x-model="registerForm.email" type="email" required class="appearance-none rounded-xl relative block w-full px-4 py-2.5 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="邮箱地址" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.register.email }">
                        <p class="mt-1 text-xs text-red-500" x-show="errors.register.email" x-text="errors.register.email"></p>
                    </div>
                    <div>
                        <label for="reg-password" class="sr-only">密码</label>
                        <input id="reg-password" x-model="registerForm.password" type="password" required class="appearance-none rounded-xl relative block w-full px-4 py-2.5 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="密码 (至少6位)" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.register.password }">
                        <p class="mt-1 text-xs text-red-500" x-show="errors.register.password" x-text="errors.register.password"></p>
                    </div>
                    <div>
                        <label for="reg-confirm-password" class="sr-only">确认密码</label>
                        <input id="reg-confirm-password" x-model="registerForm.confirmPassword" type="password" required class="appearance-none rounded-xl relative block w-full px-4 py-2.5 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="确认密码" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.register.confirmPassword }">
                        <p class="mt-1 text-xs text-red-500" x-show="errors.register.confirmPassword" x-text="errors.register.confirmPassword"></p>
                    </div>
                    <div>
                        <div class="flex gap-3">
                            <div class="flex-1">
                                <label for="reg-captcha" class="sr-only">验证码</label>
                                <input id="reg-captcha" x-model="registerForm.captcha" type="text" required class="appearance-none rounded-xl relative block w-full px-4 py-2.5 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="验证码" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.register.captcha }">
                            </div>
                            <div class="relative w-32 h-[42px] flex-shrink-0 cursor-pointer rounded-xl border border-gray-200 overflow-hidden bg-gray-50 hover:opacity-80 transition-opacity" @click="refreshCaptcha" title="点击刷新">
                                <div x-show="captchaLoading || !captchaImg" class="absolute inset-0 flex items-center justify-center animate-pulse">
                                    <svg class="h-5 w-5 text-gray-400 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                </div>
                                <img x-show="!captchaLoading && captchaImg" :src="captchaImg" alt="验证码" class="w-full h-full object-cover" />
                            </div>
                        </div>
                        <p class="mt-1 text-xs text-red-500" x-show="errors.register.captcha" x-text="errors.register.captcha"></p>
                    </div>
                </div>

                <div class="flex items-center mt-2">
                    <input id="agree-terms" x-model="registerForm.agree" type="checkbox" required class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                    <label for="agree-terms" class="ml-2 block text-sm text-gray-900">
                        我同意 <a href="/terms-of-service" target="_blank" class="font-medium text-blue-600 hover:text-blue-500">用户协议</a> 和 <a href="/privacy-policy" target="_blank" class="font-medium text-blue-600 hover:text-blue-500">隐私政策</a>
                    </label>
                </div>

                <div class="rounded-md bg-red-50 p-4" x-show="errors.register.general">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-red-800" x-text="errors.register.general"></h3>
                        </div>
                    </div>
                </div>

                <div>
                    <button type="submit" :disabled="loading.register" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-gray-900 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 disabled:opacity-70 disabled:cursor-not-allowed transition-all shadow-lg shadow-gray-200 hover:shadow-gray-300">
                        <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                            <svg x-show="loading.register" class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                        </span>
                        <span x-text="loading.register ? '注册中...' : '注册'"></span>
                    </button>
                </div>
            </form>

            <!-- Forgot Password Form -->
            <form x-show="activeTab === 'forgot'" @submit.prevent="handleForgot" class="mt-8 space-y-6" style="display: none;" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
                <div class="space-y-4 rounded-md">
                    <div>
                        <label for="forgot-email" class="sr-only">邮箱地址</label>
                        <input id="forgot-email" x-model="forgotForm.email" type="email" required class="appearance-none rounded-xl relative block w-full px-4 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="注册时使用的邮箱地址" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.forgot.email }">
                        <p class="mt-1 text-xs text-red-500" x-show="errors.forgot.email" x-text="errors.forgot.email"></p>
                    </div>
                    <div>
                        <div class="flex gap-3">
                            <div class="flex-1">
                                <label for="forgot-captcha" class="sr-only">验证码</label>
                                <input id="forgot-captcha" x-model="forgotForm.captcha" type="text" required class="appearance-none rounded-xl relative block w-full px-4 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm transition-colors" placeholder="验证码" :class="{ 'border-red-300 focus:ring-red-500 focus:border-red-500': errors.forgot.captcha }">
                            </div>
                            <div class="relative w-32 h-[46px] flex-shrink-0 cursor-pointer rounded-xl border border-gray-200 overflow-hidden bg-gray-50 hover:opacity-80 transition-opacity" @click="refreshCaptcha" title="点击刷新">
                                <div x-show="captchaLoading || !captchaImg" class="absolute inset-0 flex items-center justify-center animate-pulse">
                                    <svg class="h-5 w-5 text-gray-400 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                </div>
                                <img x-show="!captchaLoading && captchaImg" :src="captchaImg" alt="验证码" class="w-full h-full object-cover" />
                            </div>
                        </div>
                        <p class="mt-1 text-xs text-red-500" x-show="errors.forgot.captcha" x-text="errors.forgot.captcha"></p>
                    </div>
                </div>

                <div class="rounded-md bg-red-50 p-4" x-show="errors.forgot.general">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-red-800" x-text="errors.forgot.general"></h3>
                        </div>
                    </div>
                </div>

                <div class="rounded-md bg-green-50 p-4" x-show="success.forgot">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-green-800" x-text="success.forgot"></h3>
                        </div>
                    </div>
                </div>

                <div>
                    <button type="submit" :disabled="loading.forgot" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-70 disabled:cursor-not-allowed transition-all shadow-lg shadow-blue-200 hover:shadow-blue-300">
                         <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                            <svg x-show="loading.forgot" class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                        </span>
                        <span x-text="loading.forgot ? '发送中...' : '发送重置邮件'"></span>
                    </button>
                </div>
                
                <div class="text-center mt-4">
                     <a href="#" class="text-sm font-medium text-blue-600 hover:text-blue-500 transition-colors" @click.prevent="switchTab('login')">返回登录</a>
                </div>
            </form>
            </div>

            <!-- Right Side: Social Login (Only show on desktop or bottom on mobile) -->
            <div class="w-full md:w-1/2 bg-gray-50/50 p-8 md:p-12 flex flex-col justify-center border-t md:border-t-0 md:border-l border-gray-100" x-show="activeTab !== 'forgot'">
                <div class="mb-6">
                    <h3 class="text-sm font-medium text-gray-900 mb-4">Or continue with</h3>
                </div>

                <div class="space-y-3">
                    <button @click="handleGitHubLogin" class="w-full flex justify-center items-center px-4 py-2.5 border border-gray-200 shadow-sm text-sm font-medium rounded-xl text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 transition-colors">
                        <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                             <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                        使用 GitHub 登录
                    </button>
                    <!-- Mock buttons for visual layout as per user screenshot -->
                    <button class="w-full flex justify-center items-center px-4 py-2.5 border border-gray-200 shadow-sm text-sm font-medium rounded-xl text-gray-700 bg-white hover:bg-gray-50 transition-colors opacity-50 cursor-not-allowed">
                        <svg class="h-5 w-5 mr-2 text-red-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
                        使用 Google 登录
                    </button>
                    <button class="w-full flex justify-center items-center px-4 py-2.5 border border-gray-200 shadow-sm text-sm font-medium rounded-xl text-gray-700 bg-white hover:bg-gray-50 transition-colors opacity-50 cursor-not-allowed">
                        <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        使用 X 登录
                    </button>
                </div>
            </div>

        </div>
    </div>

    <script>
    function loginHandler() {
        return {
            activeTab: 'login',
            captchaImg: '',
            captchaId: '',
            captchaLoading: true,
            loginForm: { username: '', password: '', captcha: '' },
            registerForm: { username: '', email: '', password: '', confirmPassword: '', captcha: '', agree: false },
            forgotForm: { email: '', captcha: '' },
            errors: {
                login: {},
                register: {},
                forgot: {}
            },
            success: { forgot: '' },
            loading: { login: false, register: false, forgot: false },

            init() {
                this.refreshCaptcha();
                const urlParams = new URLSearchParams(window.location.search);
                const model = urlParams.get('model');
                if (model === 'register') {
                    this.activeTab = 'register';
                }
            },
            
            getHeaderTitle() {
                if (this.activeTab === 'login') return '登录到您的账户';
                if (this.activeTab === 'register') return '创建一个新账户';
                if (this.activeTab === 'forgot') return '重置密码';
                return 'Welcome';
            },

            switchTab(tab) {
                this.activeTab = tab;
                this.clearErrors();
            },

            clearErrors() {
                this.errors.login = {};
                this.errors.register = {};
                this.errors.forgot = {};
                this.success.forgot = '';
            },

            refreshCaptcha() {
                this.captchaLoading = true;
                if (!window.api || !window.api.getCaptcha) {
                    console.error('API not initialized');
                    this.captchaLoading = false;
                    return;
                }
                window.api.getCaptcha()
                    .then(res => {
                        this.captchaId = res.result.captchaId;
                        this.captchaImg = res.result.captchaImg;
                    })
                    .catch(err => console.error('Captcha error:', err))
                    .finally(() => {
                        this.captchaLoading = false;
                    });
            },

            async handleLogin() {
                this.clearErrors();
                if (!this.loginForm.username) this.errors.login.username = '请输入用户名';
                if (!this.loginForm.password) this.errors.login.password = '请输入密码';
                if (!this.loginForm.captcha) this.errors.login.captcha = '请输入验证码';

                if (Object.keys(this.errors.login).length > 0) return;

                this.loading.login = true;
                try {
                    await window.api.login(
                        this.loginForm.username,
                        this.loginForm.password,
                        this.captchaId,
                        this.loginForm.captcha
                    );
                    const urlParams = new URLSearchParams(window.location.search);
                    window.location.href = urlParams.get('redirect') || '/';
                } catch (e) {
                    this.errors.login.general = e.message || '登录失败';
                    this.refreshCaptcha();
                } finally {
                    this.loading.login = false;
                }
            },

            async handleRegister() {
                this.clearErrors();
                if (!this.registerForm.username) this.errors.register.username = '请输入用户名';
                if (!this.registerForm.email) this.errors.register.email = '请输入邮箱';
                else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.registerForm.email)) this.errors.register.email = '邮箱格式不正确';
                if (!this.registerForm.password) this.errors.register.password = '请输入密码';
                if (this.registerForm.password !== this.registerForm.confirmPassword) this.errors.register.confirmPassword = '密码不一致';
                if (!this.registerForm.captcha) this.errors.register.captcha = '请输入验证码';

                if (Object.keys(this.errors.register).length > 0) return;

                this.loading.register = true;
                try {
                    await window.api.register(
                        this.registerForm.username,
                        this.registerForm.email,
                        this.registerForm.password,
                        this.captchaId,
                        this.registerForm.captcha
                    );
                    const urlParams = new URLSearchParams(window.location.search);
                    window.location.href = urlParams.get('redirect') || '/';
                } catch (e) {
                    this.errors.register.general = e.message || '注册失败';
                    this.refreshCaptcha();
                } finally {
                    this.loading.register = false;
                }
            },

            async handleForgot() {
                this.clearErrors();
                if (!this.forgotForm.email) this.errors.forgot.email = '请输入邮箱';
                else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.forgotForm.email)) this.errors.forgot.email = '邮箱格式不正确';
                if (!this.forgotForm.captcha) this.errors.forgot.captcha = '请输入验证码';

                if (Object.keys(this.errors.forgot).length > 0) return;

                this.loading.forgot = true;
                try {
                    const res = await window.api.forgotPassword(
                        this.forgotForm.email,
                        this.captchaId,
                        this.forgotForm.captcha
                    );
                    this.success.forgot = '重置邮件已发送，请查收';
                } catch (e) {
                    this.errors.forgot.general = e.message || '发送失败';
                    this.refreshCaptcha();
                } finally {
                    this.loading.forgot = false;
                }
            },

            handleGitHubLogin() {
                const urlParams = new URLSearchParams(window.location.search);
                const redirectUrl = urlParams.get('redirect');
                let url = '/api/auth/github';
                if (redirectUrl) url += '?redirect=' + encodeURIComponent(redirectUrl);
                window.location.href = url;
            }
        }
    }
    </script>
</body>
</html>
