<!DOCTYPE html>
<html lang="zh-CN" data-theme="{{.Theme}}">
<head>
    {{template "common-head.gohtml" .}}
    {{GetImportInfoPath `src/main.js`}}
</head>
<body>
<div class="min-h-screen flex flex-col bg-base-200">
    <header class="sticky top-0 z-50">
        {{template "nav.gohtml" .}}
    </header>
    
    <main class="flex-1 container mx-auto px-4 py-6">
        <div class="max-w-6xl mx-auto">
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {{range .Projects}}
                <div class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow duration-300 border border-base-200 group">
                    <div class="card-body p-4">
                        <!-- 项目头部 -->
                        <div class="flex items-start mb-3">
                            <div class="w-10 h-10 rounded-lg bg-base-200 group-hover:bg-primary/10 transition-colors duration-300 flex items-center justify-center mr-3 shrink-0">
                                <svg class="w-5 h-5 text-base-content/70 group-hover:text-primary transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <h3 class="text-lg font-bold font-mono text-base-content mb-0.5 truncate group-hover:text-primary transition-colors duration-200">{{.Name}}</h3>
                                <div class="flex items-center text-xs text-base-content/50">
                                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                    {{.UpdatedAt.Format "2006-01-02"}}
                                </div>
                            </div>
                        </div>

                        <!-- 项目描述 -->
                        <p class="text-base-content/70 mb-4 text-sm leading-relaxed line-clamp-2 min-h-[3em]">{{.Description}}</p>

                        <!-- 操作按钮 -->
                        <div class="card-actions justify-between items-center mt-auto pt-3 border-t border-base-200/50">
                            <div class="flex gap-2">
                                <span class="badge badge-ghost badge-xs text-base-content/50">文档</span>
                            </div>
                            <a href="/docs/{{.Slug}}" class="btn btn-primary btn-xs btn-outline hover:!text-white gap-1">
                                开始阅读
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
                {{end}}
            </div>

            {{if not .Projects}}
            <!-- 空状态 -->
            <div class="text-center py-16 bg-base-100 rounded-2xl border border-base-200">
                <div class="w-16 h-16 rounded-full bg-base-200/50 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-base-content/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold font-mono text-base-content mb-2">暂无文档</h3>
                <p class="text-sm text-base-content/60 mb-6 max-w-md mx-auto">
                    我们正在加紧翻译更多优质内容，敬请期待。
                </p>
                <div class="flex flex-wrap justify-center gap-2">
                    <span class="px-3 py-1 rounded-full bg-base-200 text-xs font-medium text-base-content/70">🌏 中文翻译</span>
                    <span class="px-3 py-1 rounded-full bg-base-200 text-xs font-medium text-base-content/70">📖 精选教程</span>
                    <span class="px-3 py-1 rounded-full bg-base-200 text-xs font-medium text-base-content/70">🎯 实战指南</span>
                </div>
            </div>
            {{end}}

            <!-- 底部帮助区域 -->
            <div class="mt-8">
                <div class="bg-base-100 rounded-xl p-8 text-center border border-base-200">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4 text-primary">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold font-mono text-base-content mb-3">参与社区贡献</h3>
                    <p class="text-sm text-base-content/60 mb-6 max-w-xl mx-auto">
                        发现优质的技术文档？想要参与翻译工作？欢迎在社区分享您的建议和贡献，共同构建更好的中文技术文档生态。
                    </p>
                    <div class="flex flex-wrap justify-center gap-3">
                        <a href="/post" class="btn btn-primary btn-sm px-6">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                            </svg>
                            推荐文档
                        </a>
                        <a href="/about" class="btn btn-ghost btn-sm border border-base-300 hover:border-base-400 px-6">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                            </svg>
                            参与翻译
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>
    {{template "footer.gohtml" .}}
</div>
</body>
</html>
