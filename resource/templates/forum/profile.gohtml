{{define "profile_content"}}
<div class="container mx-auto px-4 py-8 max-w-6xl" x-data="profileHandler()" x-cloak>
    <div class="flex flex-col lg:flex-row gap-6">
        <!-- 左侧侧边栏：用户信息与导航 -->
        <aside class="w-full lg:w-80 flex-shrink-0 space-y-6">
            <div class="sticky top-20 space-y-4">
                <!-- 用户卡片 -->
                {{template "forum/user-card.gohtml" .UserCard}}

                <!-- 导航菜单 -->
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-4">
                        <ul class="menu bg-base-100 w-full p-0 text-left gap-1">
                            <li>
                                <a :class="{'active': tab === 'articles'}" @click.prevent="tab = 'articles'" class="gap-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                                    </svg>
                                    我的文章
                                </a>
                            </li>
                            <li>
                                <a :class="{'active': tab === 'bookmarks'}" @click.prevent="tab = 'bookmarks'" class="gap-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                                    </svg>
                                    我的收藏
                                </a>
                            </li>
                            <li>
                                <a :class="{'active': tab === 'settings'}" @click.prevent="tab = 'settings'" class="gap-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    账号设置
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </aside>

        <!-- 右侧内容区域 -->
        <main class="flex-1 min-w-0">
            <!-- 标题栏 -->
            <div class="flex items-center justify-between mb-6">
                <h1 class="text-2xl font-normal" x-text="tabName"></h1>
                <a x-show="tab === 'articles'" href="/publish" class="btn btn-primary btn-sm gap-2 shadow-sm hover:shadow-primary/30 transition-shadow">
                    {{template "icon_publish"}} 写文章
                </a>
            </div>

            <!-- 我的文章 -->
            <div x-show="tab === 'articles'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
                <div x-data="contentListHandler('articles')">
                     <!-- Loading & Empty States -->
                     <template x-if="loading && list.length === 0">
                         <div class="flex justify-center py-20"><span class="loading loading-spinner loading-lg text-primary"></span></div>
                     </template>
                     <template x-if="!loading && list.length === 0">
                         <div class="card bg-base-100 shadow-sm py-20 text-center">
                             <div class="text-6xl mb-4">📝</div>
                             <h3 class="text-lg font-normal text-base-content/70">还没有发布过文章</h3>
                             <p class="text-sm text-base-content/50 mt-2">分享你的知识和见解，从第一篇文章开始</p>
                             <div class="mt-6">
                                 <a href="/publish" class="btn btn-primary btn-sm">去创作</a>
                             </div>
                         </div>
                     </template>

                     <!-- Article List -->
                     <ul class="list bg-base-100 rounded-box shadow-sm">
                         <li class="p-4 pb-2 text-xs opacity-60 tracking-wide">已发布文章</li>
                         <template x-for="item in list" :key="item.id">
                             <li class="list-row hover:bg-base-200 group transition-colors duration-200 p-4 border-b border-base-200 last:border-b-0">
                                 <div class="text-4xl font-thin opacity-30 tabular-nums flex items-center justify-center w-12 h-12 bg-base-300 rounded-box">📄</div>
                                 <div class="list-col-grow">
                                     <div>
                                         <a :href="'/post/' + item.id" class="font-bold hover:text-primary transition-colors" x-text="item.title"></a>
                                         <span x-show="item.status === 2" class="badge badge-warning badge-xs ml-2">草稿</span>
                                     </div>
                                     <div class="text-xs font-semibold opacity-60 line-clamp-1" x-text="item.summary || '暂无摘要'"></div>
                                     <div class="flex items-center gap-4 text-xs opacity-50 mt-1">
                                         <span x-text="formatDate(item.created_at)"></span>
                                         <span class="flex items-center gap-1">
                                             {{template "icon_view"}}
                                             <span x-text="item.view_count || 0"></span>
                                         </span>
                                         <span class="flex items-center gap-1">
                                             {{template "icon_comment"}}
                                             <span x-text="item.comment_count || 0"></span>
                                         </span>
                                     </div>
                                 </div>
                                 <a :href="'/publish?id=' + item.id" class="btn btn-square btn-ghost btn-sm tooltip" data-tip="编辑">
                                     <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                     </svg>
                                 </a>
                                 <button @click="deleteArticle(item.id)" class="btn btn-square btn-ghost btn-sm text-error tooltip" data-tip="删除">
                                     <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                     </svg>
                                 </button>
                             </li>
                         </template>
                     </ul>

                     <!-- Pagination -->
                     <div class="flex justify-center mt-8" x-show="total > 0">
                         <div class="join">
                             <button class="join-item btn btn-sm" :disabled="page <= 1" @click="changePage(page - 1)">«</button>
                             <button class="join-item btn btn-sm">Page <span x-text="page"></span></button>
                             <button class="join-item btn btn-sm" :disabled="page * size >= total" @click="changePage(page + 1)">»</button>
                         </div>
                     </div>
                </div>
            </div>

            <!-- 我的收藏 -->
            <div x-show="tab === 'bookmarks'" x-cloak x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
                 <div x-data="contentListHandler('bookmarks')">
                     <!-- Loading & Empty States -->
                     <template x-if="loading && list.length === 0">
                         <div class="flex justify-center py-20"><span class="loading loading-spinner loading-lg text-primary"></span></div>
                     </template>
                     <template x-if="!loading && list.length === 0">
                         <div class="card bg-base-100 shadow-sm py-20 text-center">
                             <div class="text-6xl mb-4">⭐</div>
                             <h3 class="text-lg font-normal text-base-content/70">还没有收藏内容</h3>
                             <p class="text-sm text-base-content/50 mt-2">遇到喜欢的内容，记得收藏哦</p>
                         </div>
                     </template>

                     <!-- Bookmark List -->
                     <div class="space-y-4">
                         <template x-for="item in list" :key="item.id">
                             <div class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-300 border border-base-200">
                                 <div class="card-body p-5">
                                     <h3 class="card-title text-lg font-normal mb-2">
                                         <a :href="'/post/' + item.id" class="hover:text-primary transition-colors" x-text="item.title"></a>
                                     </h3>
                                     <p class="text-base-content/70 text-sm line-clamp-2 mb-3" x-text="item.summary || '暂无摘要'"></p>
                                     <div class="flex items-center gap-4 text-xs text-base-content/50">
                                         <div class="flex items-center gap-2">
                                             <div class="avatar placeholder">
                                                 <div class="bg-neutral text-neutral-content rounded-full w-5">
                                                     <img :src="item.user_avatar || '/static/pic/default-avatar.webp'" alt="Author">
                                                 </div>
                                             </div>
                                             <span x-text="item.user_nickname || item.username"></span>
                                         </div>
                                         <span x-text="formatDate(item.created_at)"></span>
                                         <span class="flex items-center gap-1">
                                              {{template "icon_view"}}
                                              <span x-text="item.view_count || 0"></span>
                                         </span>
                                     </div>
                                 </div>
                             </div>
                         </template>
                     </div>
                      <!-- Pagination -->
                      <div class="flex justify-center mt-8" x-show="total > 0">
                         <div class="join">
                             <button class="join-item btn btn-sm" :disabled="page <= 1" @click="changePage(page - 1)">«</button>
                             <button class="join-item btn btn-sm">Page <span x-text="page"></span></button>
                             <button class="join-item btn btn-sm" :disabled="page * size >= total" @click="changePage(page + 1)">»</button>
                         </div>
                     </div>
                 </div>
            </div>

            <!-- 账号设置 -->
            <div x-show="tab === 'settings'" x-data="settingsHandler()" x-cloak x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
                 <!-- Settings Tabs -->
                <div class="tabs tabs-lift">
                            <input type="radio" name="settings_tabs" class="tab" aria-label="基本信息" :checked="subTab === 'basic'" @click="subTab = 'basic'" />
                            <div class="tab-content bg-base-100 border-base-300 rounded-box p-6">
                             <form @submit.prevent="saveBasicInfo" class="space-y-6 max-w-4xl mx-auto py-4">
                                 <!-- 基本信息 -->
                                <!-- 头像设置 -->
                                <div class="flex items-center gap-6 mb-8">
                                    <div class="avatar">
                                        <div class="w-20 h-20 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
                                            <img :src="user.avatarUrl || '/static/pic/default-avatar.webp'" alt="Avatar" class="object-cover w-full h-full" />
                                        </div>
                                    </div>
                                    <div class="flex flex-col gap-2">
                                        <button type="button" class="btn btn-outline btn-primary btn-sm w-fit" @click="$refs.settingsAvatarInput.click()">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                            </svg>
                                            更换头像
                                        </button>
                                        <span class="text-xs text-base-content/50">支持 JPG, PNG, GIF, WEBP，最大 2MB</span>
                                        <input type="file" x-ref="settingsAvatarInput" class="hidden" accept="image/*" @change="handleAvatarUpload">
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="join w-full">
                                        <label class="floating-label join-item w-full">
                                            <span>用户名</span>
                                            <input type="text" x-model="form.username" class="input input-bordered join-item w-full" readonly />
                                        </label>
                                        <button type="button" class="btn btn-primary join-item">更改</button>
                                    </div>
                                    <div class="join w-full">
                                        <label class="floating-label join-item w-full">
                                            <span>邮箱</span>
                                            <input type="email" x-model="form.email" class="input input-bordered join-item w-full" readonly />
                                        </label>
                                        <button type="button" class="btn btn-primary join-item">更改</button>
                                    </div>
                                    <label class="floating-label w-full">
                                        <span>昵称 <span class="text-error">*</span></span>
                                        <input type="text" x-model="form.nickname" class="input input-bordered w-full focus:input-primary" required placeholder="你的昵称" />
                                    </label>
                                    <label class="floating-label w-full">
                                        <span>个性签名</span>
                                        <input type="text" x-model="form.signature" class="input input-bordered w-full focus:input-primary" placeholder="一句话介绍自己" />
                                    </label>
                                    <label class="floating-label w-full md:col-span-2">
                                        <span>个人简介</span>
                                        <textarea x-model="form.bio" class="textarea textarea-bordered h-24 w-full focus:textarea-primary leading-relaxed resize-none" placeholder="详细介绍一下你自己..."></textarea>
                                    </label>
                                </div>

                                <!-- 个人网站 -->
                                <div>
                                    <div class="divider text-sm text-base-content/50 font-normal">个人网站</div>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <label class="floating-label w-full">
                                            <span>网站名称</span>
                                            <input type="text" x-model="form.websiteName" class="input input-bordered w-full focus:input-primary" placeholder="例如：我的博客" />
                                        </label>
                                        <label class="floating-label w-full">
                                            <span>网站链接</span>
                                            <input type="url" x-model="form.website" class="input input-bordered w-full focus:input-primary" placeholder="https://" />
                                        </label>
                                    </div>
                                </div>

                                 <!-- 社交链接 -->
                                 <div>
                                     <div class="divider text-sm text-base-content/50 font-normal">社交账号</div>
                                     <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                         <!-- GitHub -->
                                         <label class="floating-label w-full">
                                            <span class="flex items-center gap-2">
                                                <svg class="w-4 h-4" viewBox="0 0 50 50" fill="currentColor">
                                                    <path d="M17.791,46.836C18.502,46.53,19,45.823,19,45v-5.4c0-0.197,0.016-0.402,0.041-0.61C19.027,38.994,19.014,38.997,19,39 c0,0-3,0-3.6,0c-1.5,0-2.8-0.6-3.4-1.8c-0.7-1.3-1-3.5-2.8-4.7C8.9,32.3,9.1,32,9.7,32c0.6,0.1,1.9,0.9,2.7,2c0.9,1.1,1.8,2,3.4,2 c2.487,0,3.82-0.125,4.622-0.555C21.356,34.056,22.649,33,24,33v-0.025c-5.668-0.182-9.289-2.066-10.975-4.975 c-3.665,0.042-6.856,0.405-8.677,0.707c-0.058-0.327-0.108-0.656-0.151-0.987c1.797-0.296,4.843-0.647,8.345-0.714 c-0.112-0.276-0.209-0.559-0.291-0.849c-3.511-0.178-6.541-0.039-8.187,0.097c-0.02-0.332-0.047-0.663-0.051-0.999 c1.649-0.135,4.597-0.27,8.018-0.111c-0.079-0.5-0.13-1.011-0.13-1.543c0-1.7,0.6-3.5,1.7-5c-0.5-1.7-1.2-5.3,0.2-6.6 c2.7,0,4.6,1.3,5.5,2.1C21,13.4,22.9,13,25,13s4,0.4,5.6,1.1c0.9-0.8,2.8-2.1,5.5-2.1c1.5,1.4,0.7,5,0.2,6.6c1.1,1.5,1.7,3.2,1.6,5 c0,0.484-0.045,0.951-0.11,1.409c3.499-0.172,6.527-0.034,8.204,0.102c-0.002,0.337-0.033,0.666-0.051,0.999 c-1.671-0.138-4.775-0.28-8.359-0.089c-0.089,0.336-0.197,0.663-0.325,0.98c3.546,0.046,6.665,0.389,8.548,0.689 c-0.043,0.332-0.093,0.661-0.151,0.987c-1.912-0.306-5.171-0.664-8.879-0.682C35.112,30.873,31.557,32.75,26,32.969V33 c2.6,0,5,3.9,5,6.6V45c0,0.823,0.498,1.53,1.209,1.836C41.37,43.804,48,35.164,48,25C48,12.318,37.683,2,25,2S2,12.318,2,25 C2,35.164,8.63,43.804,17.791,46.836z"></path>
                                                </svg>
                                                GitHub
                                            </span>
                                            <input type="text" x-model="form.externalInformation.github.link" class="input input-bordered w-full focus:input-primary font-mono text-sm" placeholder="GitHub Profile URL" />
                                         </label>

                                         <!-- Twitter / X -->
                                        <label class="floating-label w-full">
                                            <span class="flex items-center gap-2">
                                                <svg class="w-4 h-4" viewBox="0 0 50 50" fill="currentColor">
                                                    <path d="M 11 4 C 7.134 4 4 7.134 4 11 L 4 39 C 4 42.866 7.134 46 11 46 L 39 46 C 42.866 46 46 42.866 46 39 L 46 11 C 46 7.134 42.866 4 39 4 L 11 4 z M 13.085938 13 L 21.023438 13 L 26.660156 21.009766 L 33.5 13 L 36 13 L 27.789062 22.613281 L 37.914062 37 L 29.978516 37 L 23.4375 27.707031 L 15.5 37 L 13 37 L 22.308594 26.103516 L 13.085938 13 z M 16.914062 15 L 31.021484 35 L 34.085938 35 L 19.978516 15 L 16.914062 15 z"></path>
                                                </svg>
                                                Twitter / X
                                            </span>
                                            <input type="text" x-model="form.externalInformation.twitter.link" class="input input-bordered w-full focus:input-primary font-mono text-sm" placeholder="Twitter Profile URL" />
                                        </label>

                                         <!-- LinkedIn -->
                                        <label class="floating-label w-full">
                                            <span class="flex items-center gap-2">
                                                <svg class="w-4 h-4" viewBox="0 0 50 50" fill="currentColor">
                                                    <path d="M41,4H9C6.24,4,4,6.24,4,9v32c0,2.76,2.24,5,5,5h32c2.76,0,5-2.24,5-5V9C46,6.24,43.76,4,41,4z M17,20v19h-6V20H17z M11,14.47c0-1.4,1.2-2.47,3-2.47s2.93,1.07,3,2.47c0,1.4-1.12,2.53-3,2.53C12.2,17,11,15.87,11,14.47z M39,39h-6c0,0,0-9.26,0-10 c0-2-1-4-3.5-4.04h-0.08C27,24.96,26,27.02,26,29c0,0.91,0,10,0,10h-6V20h6v2.56c0,0,1.93-2.56,5.81-2.56 c3.97,0,7.19,2.73,7.19,8.26V39z"></path>
                                                </svg>
                                                LinkedIn
                                            </span>
                                            <input type="text" x-model="form.externalInformation.linkedIn.link" class="input input-bordered w-full focus:input-primary font-mono text-sm" placeholder="LinkedIn Profile URL" />
                                        </label>

                                         <!-- 微博 -->
                                         <label class="floating-label w-full">
                                            <span class="flex items-center gap-2">
                                                <svg class="w-4 h-4" viewBox="0 0 50 50" fill="currentColor">
                                                    <path d="M 35 6 C 34.222656 6 33.472656 6.078125 32.75 6.207031 C 32.207031 6.300781 31.84375 6.820313 31.9375 7.363281 C 32.03125 7.910156 32.550781 8.273438 33.09375 8.179688 C 33.726563 8.066406 34.359375 8 35 8 C 41.085938 8 46 12.914063 46 19 C 46 20.316406 45.757813 21.574219 45.328125 22.753906 C 45.195313 23.09375 45.253906 23.476563 45.484375 23.757813 C 45.71875 24.039063 46.082031 24.171875 46.441406 24.105469 C 46.800781 24.039063 47.09375 23.78125 47.207031 23.4375 C 47.710938 22.054688 48 20.566406 48 19 C 48 11.832031 42.167969 6 35 6 Z M 35 12 C 34.574219 12 34.171875 12.042969 33.789063 12.109375 C 33.246094 12.207031 32.878906 12.722656 32.976563 13.269531 C 33.070313 13.8125 33.589844 14.175781 34.132813 14.082031 C 34.425781 14.03125 34.714844 14 35 14 C 37.773438 14 40 16.226563 40 19 C 40 19.597656 39.890625 20.167969 39.691406 20.707031 C 39.503906 21.226563 39.773438 21.800781 40.292969 21.988281 C 40.8125 22.175781 41.386719 21.910156 41.574219 21.390625 C 41.84375 20.648438 42 19.84375 42 19 C 42 15.144531 38.855469 12 35 12 Z M 21.175781 12.40625 C 17.964844 12.34375 13.121094 14.878906 8.804688 19.113281 C 4.511719 23.40625 2 27.90625 2 31.78125 C 2 39.3125 11.628906 43.8125 21.152344 43.8125 C 33.5 43.8125 41.765625 36.699219 41.765625 31.046875 C 41.765625 27.59375 38.835938 25.707031 36.21875 24.871094 C 35.59375 24.660156 35.175781 24.558594 35.488281 23.71875 C 35.695313 23.21875 36 22.265625 36 21 C 36 19.5625 35 18.316406 33 18.09375 C 32.007813 17.984375 28 18 25.339844 19.113281 C 25.339844 19.113281 23.871094 19.746094 24.289063 18.59375 C 25.023438 16.292969 24.917969 14.40625 23.765625 13.359375 C 23.140625 12.730469 22.25 12.425781 21.175781 12.40625 Z M 20.3125 23.933594 C 28.117188 23.933594 34.441406 27.914063 34.441406 32.828125 C 34.441406 37.738281 28.117188 41.71875 20.3125 41.71875 C 12.511719 41.71875 6.1875 37.738281 6.1875 32.828125 C 6.1875 27.914063 12.511719 23.933594 20.3125 23.933594 Z"></path>
                                                </svg>
                                                微博
                                            </span>
                                            <input type="text" x-model="form.externalInformation.weibo.link" class="input input-bordered w-full focus:input-primary font-mono text-sm" placeholder="Weibo Profile URL" />
                                         </label>

                                         <!-- 知乎 -->
                                         <label class="floating-label w-full">
                                            <span class="flex items-center gap-2">
                                                <svg class="w-4 h-4" viewBox="0 0 32 32" fill="currentColor">
                                                    <path d="M 30.628906 8.9882812 C 30.263281 9.0304687 29.699219 9.1992188 29.699219 9.1992188 C 29.699219 9.1992188 21.499609 10.099219 18.099609 10.199219 C 18.199609 10.699219 18.500391 11.099219 18.900391 11.199219 C 19.600391 11.299219 20.100391 11.199219 21.400391 11.199219 C 22.600391 11.099219 23.599219 11.099609 24.199219 11.099609 L 24.199219 16 L 18 16 C 18 16 18.099219 17.199219 19.199219 17.199219 L 24.199219 17.199219 L 24.199219 20.599609 C 24.199219 21.299609 23.7 21.699219 23 21.699219 C 22.3 21.699219 21.8 21.599609 21 21.599609 C 21.1 21.799609 21.200391 22.299219 21.900391 22.699219 C 22.400391 22.899219 22.699219 23 23.199219 23 C 24.699219 23 25.5 22.099219 25.5 20.699219 L 25.5 17.199219 L 31.599609 17.199219 C 31.999609 17.199219 32.000391 15.999609 31.900391 16.099609 L 25.400391 16.099609 L 25.400391 11.199219 C 25.600391 11.199219 26 11.099609 26.5 11.099609 C 28.6 10.999609 30.000391 10.699219 30.900391 10.699219 C 30.900391 10.699219 31.500391 9.3 30.900391 9 C 30.850391 8.975 30.750781 8.9742188 30.628906 8.9882812 z M 3.3007812 9 C 3.3007813 9 2.0992188 8.9996094 1.6992188 10.099609 C 1.5992187 10.499609 0.9 12.100391 0 13.900391 C 0.3 13.900391 1.2007812 13.800781 1.8007812 12.800781 C 1.9007813 12.500781 2.2007812 12.300391 2.3007812 11.900391 L 3.8007812 11.900391 C 3.8007813 12.400391 3.6992188 15.500781 3.6992188 15.800781 L 1.0996094 15.800781 C 0.49960937 15.800781 0.30078125 17 0.30078125 17 L 3.5 17 C 3.3 19.4 2.1 21.100781 0 22.800781 C 1 23.100781 1.9996094 22.800391 2.5996094 22.400391 C 2.5996094 22.400391 3.8003906 21.499609 4.4003906 19.099609 L 6.9003906 22 C 6.9003906 22 7.3007812 20.6 6.8007812 20 C 6.4007813 19.5 5.5996094 18.599219 5.0996094 18.199219 L 4.4003906 18.800781 C 4.6003906 18.100781 4.8007812 17.7 4.8007812 17 L 8 17 C 8 17 7.9996094 15.800781 7.5996094 15.800781 L 4.9003906 15.800781 C 5.0003906 14.500781 5 13.000391 5 11.900391 L 7.4003906 11.900391 C 7.4003906 11.900391 7.6003906 10.6 7.1003906 10 C 6.7003906 9.5 5.9003906 9.4007813 5.4003906 9.3007812 C 4.6003906 9.1007813 3.3007812 9 3.3007812 9 z"></path>
                                                </svg>
                                                知乎
                                            </span>
                                            <input type="text" x-model="form.externalInformation.zhihu.link" class="input input-bordered w-full focus:input-primary font-mono text-sm" placeholder="Zhihu Profile URL" />
                                         </label>
                                     </div>
                                 </div>

                                 <div class="flex justify-end mt-8 pt-6 border-t border-base-200">
                                     <button type="submit" class="btn btn-primary px-8" :disabled="saving">
                                         <span x-show="!saving">保存更改</span>
                                         <span x-show="saving" class="loading loading-spinner"></span>
                                     </button>
                                 </div>
                             </form>
                         </div>

                         <!-- Password -->
                         <input type="radio" name="settings_tabs" class="tab" aria-label="修改密码" :checked="subTab === 'password'" @click="subTab = 'password'" />
                         <div class="tab-content bg-base-100 border-base-300 rounded-box p-6">
                             <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                                 <!-- 左侧表单区域 -->
                                 <div class="lg:col-span-2">
                                     <form @submit.prevent="changePassword" class="space-y-6 py-4">
                                        <label class="floating-label w-full">
                                            <span>旧密码</span>
                                            <input type="password" x-model="pwdForm.oldPassword" class="input input-bordered w-full focus:input-primary" required placeholder="请输入当前密码" />
                                        </label>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                            <label class="floating-label w-full">
                                                <span>新密码</span>
                                                <input type="password" x-model="pwdForm.newPassword" class="input input-bordered w-full focus:input-primary" required placeholder="请输入新密码" />
                                            </label>
                                            <label class="floating-label w-full">
                                                <span>确认新密码</span>
                                                <input type="password" x-model="pwdForm.confirmPassword" class="input input-bordered w-full focus:input-primary" required placeholder="请再次输入新密码" />
                                            </label>
                                        </div>
                                         <div class="flex justify-end mt-8 pt-6 border-t border-base-200">
                                            <button type="submit" class="btn btn-primary px-8" :disabled="saving">
                                                <span x-show="!saving">修改密码</span>
                                                <span x-show="saving" class="loading loading-spinner"></span>
                                            </button>
                                        </div>
                                     </form>
                                 </div>
                                 
                                 <!-- 右侧安全提示 -->
                                 <div class="lg:col-span-1">
                                     <div class="card bg-base-200/50 compact mt-4 lg:mt-0">
                                         <div class="card-body">
                                             <h3 class="card-title text-base flex items-center gap-2">
                                                 <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                 </svg>
                                                 安全提示
                                             </h3>
                                             <ul class="text-sm text-base-content/70 space-y-3 mt-2">
                                                 <li class="flex gap-2">
                                                     <span class="text-success">•</span>
                                                     <span>密码长度至少需要 6 个字符。</span>
                                                 </li>
                                                 <li class="flex gap-2">
                                                     <span class="text-success">•</span>
                                                     <span>建议使用字母、数字和符号的组合以提高安全性。</span>
                                                 </li>
                                                 <li class="flex gap-2">
                                                     <span class="text-success">•</span>
                                                     <span>请勿使用与其他网站相同的密码。</span>
                                                 </li>
                                                 <li class="flex gap-2">
                                                     <span class="text-success">•</span>
                                                     <span>定期修改密码可以有效保护您的账号安全。</span>
                                                 </li>
                                             </ul>
                                         </div>
                                     </div>
                                 </div>
                             </div>
                        </div>

                        <!-- Account Binding -->
                        <input type="radio" name="settings_tabs" class="tab" aria-label="账号绑定" :checked="subTab === 'binding'" @click="subTab = 'binding'" />
                        <div class="tab-content bg-base-100 border-base-300 rounded-box p-6">
                            <div class="space-y-4 mt-4">
                                <template x-if="loadingBindings">
                                    <div class="flex justify-center py-10"><span class="loading loading-spinner loading-lg text-primary"></span></div>
                                </template>
                                <template x-if="!loadingBindings">
                                    <div class="grid grid-cols-1 gap-4">
                                        <template x-for="(binding, provider) in oauthBindings" :key="provider">
                                            <div class="flex items-center justify-between p-4 bg-base-100 border border-base-200 rounded-lg shadow-sm hover:shadow-md transition-shadow">
                                                <div class="flex items-center gap-4">
                                                    <div class="w-10 h-10 rounded-full bg-base-200 flex items-center justify-center text-xl shrink-0">
                                                        <!-- Icons based on provider -->
                                                        <template x-if="provider === 'github'">
                                                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                                                        </template>
                                                        <template x-if="provider === 'google'">
                                                            <svg class="w-6 h-6" viewBox="0 0 24 24"><path fill="#EA4335" d="M24 12.276c0-.852-.076-1.671-.219-2.456H12v4.646h6.73c-.29 1.556-1.171 2.873-2.496 3.76v3.128h4.043c2.365-2.179 3.73-5.392 3.73-9.078z"/><path fill="#34A853" d="M12 24c3.24 0 5.957-1.074 7.942-2.908l-4.043-3.128c-1.075.72-2.451 1.146-3.899 1.146-3.126 0-5.772-2.112-6.72-4.952H1.206v3.111C3.177 21.087 7.288 24 12 24z"/><path fill="#FBBC05" d="M5.28 15.158c-.247-.738-.389-1.528-.389-2.342 0-.814.142-1.604.389-2.342V7.363H1.206C.437 8.894 0 10.612 0 12.184c0 1.572.437 3.289 1.206 4.821l4.074-3.847z"/><path fill="#4285F4" d="M12 4.77c1.762 0 3.344.606 4.59 1.796l3.443-3.443C17.954 1.218 15.238 0 12 0 7.288 0 3.177 2.913 1.206 7.363l4.074 3.847c.948-2.84 3.594-4.952 6.72-4.952z"/></svg>
                                                        </template>
                                                    </div>
                                                    <div>
                                                        <div class="font-medium capitalize" x-text="provider"></div>
                                                        <div class="text-sm opacity-70" x-text="binding.bound ? '已绑定' : '未绑定'"></div>
                                                    </div>
                                                </div>
                                                <button class="btn btn-sm" :class="binding.bound ? 'btn-outline btn-error' : 'btn-outline btn-primary'" @click="binding.bound ? unbindOAuth(provider) : bindOAuth(provider)">
                                                    <span x-text="binding.bound ? '解绑' : '绑定'"></span>
                                                </button>
                                            </div>
                                        </template>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
            </div>
        </main>

        <!-- Avatar Crop Modal -->
        <div x-show="cropping" class="fixed inset-0 z-50 flex items-center justify-center bg-black/70 p-4" x-transition.opacity style="display: none;">
            <div class="bg-base-100 rounded-box shadow-xl max-w-2xl w-full flex flex-col max-h-[90vh]">
                <div class="p-4 border-b border-base-200 flex justify-between items-center">
                    <h3 class="text-lg font-bold">裁切头像</h3>
                    <button @click="cancelCrop" class="btn btn-ghost btn-sm btn-circle">✕</button>
                </div>
                <div class="p-4 flex-1 overflow-hidden bg-base-200 flex justify-center items-center relative" style="min-height: 300px;">
                     <img x-ref="cropImage" :src="cropImage" class="max-w-full max-h-[60vh] block" style="display: block; max-width: 100%;">
                </div>
                <div class="p-4 border-t border-base-200 flex justify-end gap-3">
                    <button @click="cancelCrop" class="btn btn-ghost">取消</button>
                    <button @click="saveCrop" class="btn btn-primary">裁切并上传</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function profileHandler() {
        return {
            tab: 'articles',
            user: {{json .User}},
            stats: {{json .Stats}},
            get tabName() {
                switch(this.tab) {
                    case 'articles': return '我的文章';
                    case 'bookmarks': return '我的收藏';
                    case 'settings': return '账号设置';
                    default: return '';
                }
            },
            init() {
                const path = window.location.pathname;
                if (path.includes('/settings')) {
                    this.tab = 'settings';
                }
            },
            cropping: false,
            cropImage: '',
            cropper: null,
            handleAvatarUpload(e) {
                const file = e.target.files[0];
                if (!file) return;

                if (file.size > 5 * 1024 * 1024) {
                    alert('图片大小不能超过 5MB');
                    return;
                }
                
                // Clear input to allow re-selecting same file
                e.target.value = '';

                const reader = new FileReader();
                reader.onload = (e) => {
                    this.cropImage = e.target.result;
                    this.cropping = true;
                    this.$nextTick(() => {
                        this.initCropper();
                    });
                };
                reader.readAsDataURL(file);
            },
            initCropper() {
                if (this.cropper) {
                    this.cropper.destroy();
                }
                const image = this.$refs.cropImage;
                this.cropper = new window.Cropper(image, {
                    aspectRatio: 1,
                    viewMode: 1,
                    autoCropArea: 1,
                    responsive: true
                });
            },
            cancelCrop() {
                this.cropping = false;
                if (this.cropper) {
                    this.cropper.destroy();
                    this.cropper = null;
                }
            },
            saveCrop() {
                if (!this.cropper) return;
                
                // Get cropped canvas
                const canvas = this.cropper.getCroppedCanvas({
                    width: 400,
                    height: 400,
                    imageSmoothingEnabled: true,
                    imageSmoothingQuality: 'high',
                });
                
                canvas.toBlob(async (blob) => {
                    if (!blob) {
                        alert('裁切失败');
                        return;
                    }
                    
                    // Convert blob to file
                    const file = new File([blob], 'avatar.webp', { type: 'image/webp' });
                    
                    // Use processImageFile for consistent handling (though we already have webp)
                    // Or just upload directly. Since we forced webp in toBlob, we can just upload.
                    
                    const formData = new FormData();
                    formData.append('avatar', file);

                    try {
                        const res = await axios.post('/api/upload-avatar', formData, {
                            headers: { 'Content-Type': 'multipart/form-data' }
                        });
                        if (res.data.code === 0) {
                            this.user.avatarUrl = res.data.result.avatarUrl || res.data.result;
                            alert('头像上传成功');
                            location.reload();
                        } else {
                            alert(res.data.msg || '上传失败');
                        }
                    } catch (error) {
                        console.error('Upload failed', error);
                        alert('上传出错，请重试');
                    }
                }, 'image/webp', 0.85);
            }
        }
    }

    function contentListHandler(type) {
        return {
            type: type, // 'articles' or 'bookmarks'
            list: [],
            page: 1,
            size: 10,
            total: 0,
            loading: false,
            init() {
                this.fetchData();
            },
            async fetchData() {
                this.loading = true;
                try {
                    const url = this.type === 'articles' ? '/api/forum/get-user-articles' : '/api/forum/get-user-bookmarked-articles';
                    // API expects post with page, size
                    const res = await axios.post(url, {
                        page: this.page,
                        size: this.size
                    });
                    if (res.data.code === 0) {
                        this.list = res.data.result.list || [];
                        this.total = res.data.result.total || 0;
                    }
                } catch (e) {
                    console.error('Fetch failed', e);
                } finally {
                    this.loading = false;
                }
            },
            changePage(p) {
                if (p < 1 || (p > 1 && (p - 1) * this.size >= this.total)) return;
                this.page = p;
                this.fetchData();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            },
            async deleteArticle(id) {
                if (!confirm('确定要删除这篇文章吗？此操作不可恢复。')) return;
                try {
                    const res = await axios.post('/post/delete', { id: id });
                    if (res.data.code === 0) {
                        this.fetchData();
                        // Update stats locally
                        // This requires access to parent scope. Alpine supports $data or custom events.
                        // Ideally emit event.
                    } else {
                        alert(res.data.msg || '删除失败');
                    }
                } catch (e) {
                    alert('删除请求失败');
                }
            },
            formatDate(dateStr) {
                if (!dateStr) return '';
                const date = new Date(dateStr);
                return date.toLocaleDateString() + ' ' + date.toLocaleTimeString().slice(0, 5);
            }
        }
    }

    function settingsHandler() {
        return {
            subTab: 'basic',
            form: JSON.parse(JSON.stringify({{json .FullUser}})), // Clone
            pwdForm: { oldPassword: '', newPassword: '', confirmPassword: '' },
            saving: false,
            oauthBindings: {},
            loadingBindings: false,
            privacy: {
                showArticles: true,
                showFollowing: true,
                emailNotifications: true
            },
            init() {
                // Ensure externalInformation exists
                if (!this.form.externalInformation) this.form.externalInformation = {};
                ['github', 'twitter', 'linkedIn', 'weibo', 'zhihu'].forEach(key => {
                    if (!this.form.externalInformation[key]) this.form.externalInformation[key] = { link: '' };
                });

                // Check URL params for tab selection and messages
                const urlParams = new URLSearchParams(window.location.search);
                const settingTab = urlParams.get('setting-tab');
                if (settingTab === 'account') {
                    this.subTab = 'binding';
                }

                const error = urlParams.get('error');
                const success = urlParams.get('success');
                if (error) alert('操作失败: ' + error);
                if (success === 'bind_success') alert('绑定成功');

                // Load bindings if on binding tab
                this.$watch('subTab', (val) => {
                    if (val === 'binding') this.fetchBindings();
                });
                if (this.subTab === 'binding') this.fetchBindings();

                // Load privacy settings from local storage if available (mock)
                const savedPrivacy = localStorage.getItem('privacySettings');
                if (savedPrivacy) {
                    this.privacy = JSON.parse(savedPrivacy);
                }
            },
            async fetchBindings() {
                this.loadingBindings = true;
                try {
                    const res = await axios.get('/api/oauth/bindings');
                    if (res.data.code === 0) {
                        this.oauthBindings = res.data.result;
                    }
                } catch (e) {
                    console.error('Fetch bindings failed', e);
                } finally {
                    this.loadingBindings = false;
                }
            },
            bindOAuth(provider) {
                window.location.href = '/api/auth/' + provider;
            },
            async unbindOAuth(provider) {
                if (!confirm(`确定要解绑 ${provider} 账户吗？`)) return;
                try {
                    const res = await axios.post(`/api/auth/${provider}/unbind`);
                    if (res.data.code === 0) {
                        alert('解绑成功');
                        this.fetchBindings();
                    } else {
                        alert(res.data.msg || '解绑失败');
                    }
                } catch (e) {
                    alert('请求失败');
                }
            },
            savePrivacy() {
                // Mock save
                localStorage.setItem('privacySettings', JSON.stringify(this.privacy));
                console.log('Privacy settings saved', this.privacy);
            },
            async saveBasicInfo() {
                this.saving = true;
                try {
                    const res = await axios.post('/api/set-user-info', this.form);
                    if (res.data.code === 0) {
                        alert('保存成功');
                        // Update global user object?
                        // Reload page is easiest to sync everything
                        location.reload(); 
                    } else {
                        alert(res.data.msg || '保存失败');
                    }
                } catch (e) {
                    alert('请求失败');
                } finally {
                    this.saving = false;
                }
            },
            async changePassword() {
                if (this.pwdForm.newPassword !== this.pwdForm.confirmPassword) {
                    alert('两次输入的密码不一致');
                    return;
                }
                this.saving = true;
                try {
                    const res = await axios.post('/api/change-password', {
                        oldPassword: this.pwdForm.oldPassword,
                        newPassword: this.pwdForm.newPassword
                    });
                    if (res.data.code === 0) {
                        alert('密码修改成功，请重新登录');
                        location.href = '/login';
                    } else {
                        alert(res.data.msg || '修改失败');
                    }
                } catch (e) {
                    alert('请求失败');
                } finally {
                    this.saving = false;
                }
            }
        }
    }
</script>
{{end}}
{{template "layout/main.gohtml" dict "Body" "profile_content" "Data" . "Entry" "src/main.js"}}