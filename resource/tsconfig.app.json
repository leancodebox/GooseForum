{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*", "src/admin/views/WebSettings.vue"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,

    "paths": {
      "@/*": ["./src/*"],
      "@admin/*": ["./src/admin/*"],
    }
  }
}
