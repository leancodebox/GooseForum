<!DOCTYPE html>
<html lang="{{.Lang}}">
<head>
    <meta charset="UTF-8">
    <title>{{call .T "email.passwordReset.subject"}}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .container {
            background-color: #f9f9f9;
            border-radius: 5px;
            padding: 20px;
            margin-top: 20px;
        }
        .button {
            display: inline-block;
            padding: 10px 20px;
            background-color: #FF6B6B;
            color: white;
            text-decoration: none;
            border-radius: 3px;
            margin: 20px 0;
        }
        .note {
            font-size: 0.9em;
            color: #666;
            margin-top: 20px;
        }
        .warning {
            background-color: #fff3cd;
            border: 1px solid #ffeaa7;
            border-radius: 3px;
            padding: 10px;
            margin: 15px 0;
            color: #856404;
        }
    </style>
</head>
<body>
<div class="container">
    <h2>{{call .T "email.passwordReset.heading"}}</h2>
    <p>{{call .T "email.greeting" "username" .Username}}</p>
    <p>{{call .T "email.passwordReset.instruction"}}</p>
    <a href="{{.ResetLink}}" class="button">{{call .T "email.passwordReset.button"}}</a>
    <p class="note">{{call .T "email.copyLink"}}</p>
    <p>{{.ResetLink}}</p>
    <div class="warning">
        <strong>{{call .T "email.passwordReset.securityTitle"}}</strong>
        <ul>
            <li>{{call .T "email.passwordReset.expires"}}</li>
            <li>{{call .T "email.passwordReset.ignore"}}</li>
            <li>{{call .T "email.passwordReset.keepPrivate"}}</li>
        </ul>
    </div>
    <p class="note">{{call .T "email.passwordReset.contact"}}</p>
</div>
</body>
</html>
